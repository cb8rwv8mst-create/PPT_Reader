# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 文件存储路径（可选，默认项目根目录下）
UPLOAD_DIR=./uploads
AUDIO_DIR=./audio

# Edge TTS 配置（可选）
# EDGE_TTS_PATH 留空则自动检测常见路径
# EDGE_TTS_PATH=/Users/chen./Library/Python/3.13/bin/edge-tts
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# 视觉识别 API（可选，用于识别 PPT 中的图片和公式）
# VISION_API_KEY 留空则跳过图片识别
VISION_API_KEY=sk-your-vision-key
VISION_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3.6-flash
